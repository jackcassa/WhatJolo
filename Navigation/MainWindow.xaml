<Window x:Class="Navigation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Navigation"
        Icon="Assets/app-icon.png"
        Width="1220"
        Height="860"
        MinWidth="980"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        Background="#111111">
    <Window.Resources>
        <SolidColorBrush x:Key="ComboBgBrush" Color="#000000" />
        <SolidColorBrush x:Key="ComboBorderBrush" Color="#FF9900" />
        <SolidColorBrush x:Key="ComboFgBrush" Color="#FFD400" />
        <SolidColorBrush x:Key="ComboPopupBgBrush" Color="#0D0D0D" />
        <SolidColorBrush x:Key="ComboItemHoverBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="ComboItemSelectedBrush" Color="#3A2A00" />

        <Style x:Key="DarkComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ComboFgBrush}" />
            <Setter Property="Background" Value="{StaticResource ComboPopupBgBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ComboItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ComboItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource ComboFgBrush}" />
            <Setter Property="Background" Value="{StaticResource ComboBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ComboBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4,8,4" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid"
          Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder"
                Grid.Row="0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#FF9900"
                Background="#1A1A1A">
            <StackPanel>
                <TextBlock Text="Navigation"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFD400" />
                <TextBlock Margin="0,8,0,0"
                           Text="Autoconnect PostgreSQL e selezione progetto dal DB"
                           Foreground="#FFF2B3"
                           FontSize="14" />
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding CurrentContactName, StringFormat=Contatto in corso: {0}}"
                               Foreground="#FFD400"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentContactId, StringFormat=Id contatto: {0}}"
                                   Foreground="#FFF2B3"
                                   FontSize="14" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SentContactsCount, StringFormat=Totale inviati: {0}}"
                                   Foreground="#FFF2B3"
                                   FontSize="14"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="ConnectionBorder"
                Grid.Row="1"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Connection preview"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFD400" />
                    <TextBox Margin="0,8,0,0"
                             IsReadOnly="True"
                             Text="{Binding ConnectionPreview, Mode=OneWay}"
                             Background="#111111"
                             Foreground="#FFD400"
                             BorderBrush="#FF9900"
                             FontSize="14"
                             FontFamily="Consolas" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding DbStatusText}"
                               Foreground="#FFF2B3"
                               FontSize="15"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                    <TextBlock Text="Macchina"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFD400" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding MachineName}"
                               Foreground="#FFF2B3"
                               FontSize="14" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding IpSummary}"
                               Foreground="#FFF2B3"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ProjectBorder"
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#FF9900"
                Background="#1A1A1A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Progetto dal DB"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#FFD400" />

                <ComboBox Grid.Row="1"
                          Margin="0,8,0,0"
                          Height="36"
                          ItemsSource="{Binding ProjectNames}"
                          SelectedItem="{Binding SelectedProjectName}"
                          Style="{StaticResource DarkComboBoxStyle}"
                          FontSize="14"
                          ToolTip="Seleziona il progetto su cui eseguire workflow e modelli." />

                <Grid Grid.Row="2"
                      Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            MinWidth="150"
                            Height="36"
                            Click="RefreshProjects_Click"
                            Content="Aggiorna progetti"
                            FontWeight="Bold"
                            Background="#FFD400"
                            Foreground="Black"
                            BorderBrush="#FF9900"
                            ToolTip="Ricarica elenco progetti dal database." />
                    <TextBlock Grid.Column="1"
                               Margin="14,0,8,0"
                               VerticalAlignment="Center"
                               Text="Lista invio"
                               Foreground="#FFF2B3"
                               FontSize="13" />
                    <ComboBox Grid.Column="2"
                              Width="220"
                              Height="36"
                              ItemsSource="{Binding SendListModes}"
                              SelectedItem="{Binding SelectedSendListMode}"
                              Style="{StaticResource DarkComboBoxStyle}"
                              FontSize="14"
                              ToolTip="Scegli quale lista contatti inviare: fisso, migration, agenda, test, ecc." />
                </Grid>

                <WrapPanel Grid.Row="3"
                           Margin="0,10,0,0"
                           ItemHeight="24">
                    <CheckBox Content="cerca standard"
                              IsChecked="{Binding UseStandardSearch}"
                              Foreground="#FFF2B3"
                              Margin="0,0,18,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Usa KEYCODE_SEARCH invece del rilevamento YOLO per aprire la ricerca." />
                    <CheckBox Content="back standard"
                              IsChecked="{Binding UseStandardBack}"
                              Foreground="#FFF2B3"
                              Margin="0,0,18,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Usa KEYCODE_BACK invece della detection YOLO del pulsante back." />
                    <CheckBox Content="OCR chat"
                              IsChecked="{Binding UseChatOcr}"
                              Foreground="#FFF2B3"
                              Margin="0,0,18,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Abilita validazione OCR sul risultato chat prima di procedere." />
                    <CheckBox Content="OCR stop contatto"
                              IsChecked="{Binding StopContactOnOcrReject}"
                              IsEnabled="{Binding UseChatOcr}"
                              Foreground="#FFF2B3"
                              Margin="0,0,18,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Se OCR fallisce, salta solo il contatto corrente." />
                    <CheckBox Content="OCR stop workflow"
                              IsChecked="{Binding StopWorkflowOnOcrReject}"
                              IsEnabled="{Binding UseChatOcr}"
                              Foreground="#FFF2B3"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Se OCR fallisce, interrompe l'intero workflow." />
                    <CheckBox Content="Invio (paste)"
                              IsChecked="{Binding UsePasteAfterChat}"
                              Foreground="#FFF2B3"
                              Margin="18,0,0,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Dopo tap su chat invia KEYCODE_PASTE prima di cercare 'invio'." />
                    <CheckBox Content="Doppio back"
                              IsChecked="{Binding UseDoubleBack}"
                              Foreground="#FFF2B3"
                              Margin="18,0,0,0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              ToolTip="Se attivo esegue due KEYCODE_BACK consecutivi a fine invio." />
                </WrapPanel>

                <Grid Grid.Row="4"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Margin="0,0,8,0"
                            Height="38"
                            Click="Send_Click"
                            Content="Send"
                            FontWeight="Bold"
                            Background="#FF9900"
                            Foreground="Black"
                            BorderBrush="#FFD400"
                            ToolTip="Avvia il workflow di invio usando la lista scelta in combo." />
                    <Button Grid.Column="1"
                            Margin="4,0,4,0"
                            Height="38"
                            Click="Stop_Click"
                            Content="Ferma workflow"
                            FontWeight="Bold"
                            Background="#3A3A3A"
                            Foreground="#FFD400"
                            BorderBrush="#FFD400"
                            ToolTip="Interrompe il workflow in esecuzione." />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Height="38"
                            Click="ResetSent_Click"
                            Content="Azzera inviati"
                            FontWeight="Bold"
                            Background="#555555"
                            Foreground="#FFD400"
                            BorderBrush="#FFD400"
                            ToolTip="Resetta il flag 'sent' di tutti i contatti." />
                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Height="38"
                            Click="ResetExclude_Click"
                            Content="Azzera exclude"
                            FontWeight="Bold"
                            Background="#555555"
                            Foreground="#FFD400"
                            BorderBrush="#FFD400"
                            ToolTip="Resetta il flag 'exclude' di tutti i contatti." />
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="PreviewBorder"
                Grid.Row="3"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="#6E6E6E"
                           Text="Nessuna acquisizione disponibile."
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LastCapturePreview}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Image x:Name="PreviewImage"
                       Source="{Binding LastCapturePreview, Mode=OneWay}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border x:Name="StatusBorder"
                Grid.Row="4"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           Margin="0,0,0,8">
                    <TextBlock Text="Log workflow"
                               Foreground="#FFD400"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <CheckBox DockPanel.Dock="Right"
                              Content="Auto-scroll"
                              IsChecked="{Binding AutoScrollWorkflowLog}"
                              Foreground="#FFF2B3"
                              VerticalAlignment="Center" />
                </DockPanel>
                <TextBox x:Name="WorkflowLogTextBox"
                         Grid.Row="1"
                         Text="{Binding WorkflowLogText, Mode=OneWay}"
                         TextChanged="WorkflowLogTextBox_TextChanged"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#111111"
                         Foreground="#FFD400"
                         BorderThickness="0"
                         FontSize="15"
                         FontFamily="Consolas" />
            </Grid>
        </Border>
    </Grid>
</Window>
