<Window x:Class="Navigation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Navigation"
        Width="980"
        Height="680"
        MinWidth="520"
        MinHeight="620"
        Background="#111111">
    <Grid x:Name="RootGrid"
          Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder"
                Grid.Row="0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#FF9900"
                Background="#1A1A1A">
            <StackPanel>
                <TextBlock Text="Navigation"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFD400" />
                <TextBlock Margin="0,8,0,0"
                           Text="Autoconnect PostgreSQL e selezione progetto dal DB"
                           Foreground="#FFF2B3"
                           FontSize="14" />
            </StackPanel>
        </Border>

        <Border x:Name="ConnectionBorder"
                Grid.Row="1"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Connection preview"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFD400" />
                    <TextBox Margin="0,8,0,0"
                             IsReadOnly="True"
                             Text="{Binding ConnectionPreview, Mode=OneWay}"
                             Background="#111111"
                             Foreground="#FFD400"
                             BorderBrush="#FF9900"
                             FontSize="14"
                             FontFamily="Consolas" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding DbStatusText}"
                               Foreground="#FFF2B3"
                               FontSize="15"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                    <TextBlock Text="Macchina"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFD400" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding MachineName}"
                               Foreground="#FFF2B3"
                               FontSize="14" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding IpSummary}"
                               Foreground="#FFF2B3"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ProjectBorder"
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#FF9900"
                Background="#1A1A1A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Progetto dal DB"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFD400" />
                    <ComboBox Margin="0,8,0,0"
                              Height="34"
                              ItemsSource="{Binding ProjectNames}"
                              SelectedItem="{Binding SelectedProjectName}"
                              Background="#111111"
                              Foreground="#FFD400"
                              BorderBrush="#FF9900"
                              FontSize="14" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="18,26,0,0">
                    <Button Width="150"
                            Height="38"
                            Click="RefreshProjects_Click"
                            Content="Aggiorna progetti"
                            FontWeight="Bold"
                            Background="#FFD400"
                            Foreground="Black"
                            BorderBrush="#FF9900" />
                    <Button Margin="0,10,0,0"
                            Width="150"
                            Height="38"
                            Click="Send_Click"
                            Content="Send"
                            FontWeight="Bold"
                            Background="#FF9900"
                            Foreground="Black"
                            BorderBrush="#FFD400" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="PreviewBorder"
                Grid.Row="3"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="#6E6E6E"
                           Text="Nessuna acquisizione disponibile."
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LastCapturePreview}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Image x:Name="PreviewImage"
                       Source="{Binding LastCapturePreview, Mode=OneWay}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border x:Name="StatusBorder"
                Grid.Row="4"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#5A5A5A"
                Background="#181818">
            <TextBox Text="{Binding StatusText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#111111"
                     Foreground="#FFD400"
                     BorderThickness="0"
                     FontSize="15"
                     FontFamily="Consolas" />
        </Border>
    </Grid>
</Window>
